----- SOURCE CODE

pub effect Log {
  Emit(String) -> Nil
}

fn log_something(msg: String) -> Nil {
  Emit(msg)
}

pub fn run() -> Nil {
  log_something("hi")
}


----- COMPILED JAVASCRIPT
function* log_something(msg) {
  return yield { type: "Log.Emit", args: [msg] };
}

export function* run() {
  return yield* log_something("hi");
}
