pub effect Http {
  Request(String, Int) -> String
}

pub fn call(url: String, port: Int) -> String {
  Request(url, port)
}


----- COMPILED JAVASCRIPT
export function* call(url, port) {
  return yield { type: "Http.Request", args: [url, port] };
}
