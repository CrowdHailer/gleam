----- SOURCE CODE

pub effect Log {
  Emit(String) -> Nil
}

fn step_one(msg: String) -> Nil {
  Emit(msg)
}

pub fn step_two(msg: String) -> Nil {
  step_one(msg)
  step_one("done")
}


----- COMPILED JAVASCRIPT
function* step_one(msg) {
  return yield { type: "Log.Emit", args: [msg] };
}

export function* step_two(msg) {
  yield* step_one(msg);
  return yield* step_one("done");
}
