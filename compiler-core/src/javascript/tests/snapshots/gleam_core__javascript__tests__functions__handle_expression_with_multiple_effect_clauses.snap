----- SOURCE CODE

pub effect Store {
  Get() -> Int
  Set(Int) -> Nil
}

fn computation() -> Int {
  let x = Get()
  Set(x + 1)
  x
}

pub fn run(state: Int) -> #(Int, Int) {
  handle computation() with state {
    Store.Get(resume) -> resume(state, state)
    Store.Set(value, resume) -> resume(Nil, value)
    Return(v) -> #(v, state)
  }
}


----- COMPILED JAVASCRIPT
function* computation() {
  let x = yield { type: "Store.Get", args: [] };
  yield { type: "Store.Set", args: [x + 1] };
  return x;
}

export function run(state) {
  return (() => { const gen = computation();
    const loop = (state, $next) => {
      const $r = gen.next($next);
      if ($r.done) {
        const v = $r.value;
        return [v, state];
      }
      const $effect = $r.value;
      if ($effect.type === "Store.Get") {
        const resume = ($res, $ns) => loop($ns, $res);
        return resume(state, state);
      }
      if ($effect.type === "Store.Set") {
        const value = $effect.args[0];
        const resume = ($res, $ns) => loop($ns, $res);
        return resume(undefined, value);
      }
    };
    return loop(state, undefined); })();
}
