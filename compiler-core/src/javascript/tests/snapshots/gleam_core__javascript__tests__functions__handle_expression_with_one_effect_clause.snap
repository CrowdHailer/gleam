----- SOURCE CODE

pub effect Store {
  Get() -> Int
}

fn computation() -> Int {
  Get()
}

pub fn run(state: Int) -> Int {
  handle computation() with state {
    Store.Get(resume) -> resume(state, state)
    Return(v) -> v
  }
}


----- COMPILED JAVASCRIPT
function* computation() {
  return yield { type: "Store.Get", args: [] };
}

export function run(state) {
  return (() => { const gen = computation();
    const loop = (state, $next) => {
      const $r = gen.next($next);
      if ($r.done) {
        const v = $r.value;
        return v;
      }
      const $effect = $r.value;
      if ($effect.type === "Store.Get") {
        const resume = ($res, $ns) => loop($ns, $res);
        return resume(state, state);
      }
    };
    return loop(state, undefined); })();
}
